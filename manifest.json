{
  "manifest_version": 3,
  "name": "Steam RUB",
  "version": "1.1.0",
  "description": "Adds ruble prices next to Steam prices on store.steampowered.com.",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://store.steampowered.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://open.er-api.com/*"
  ]
}
